# Optional overrides for docker-compose. The defaults work out of the box, so
# you only need this file to change the database credentials or name.
#
# Copy to .env (which is gitignored) and edit. docker-compose reads .env
# automatically for the ${...} substitutions in docker-compose.yml.

POSTGRES_USER=medune
POSTGRES_PASSWORD=medune
POSTGRES_DB=medune
